# 飞书自建应用凭证（open.feishu.cn -> 应用后台 -> 凭证与基础信息）
APP_ID=cli_xxxxxxxxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：默认读取 config/groups.json
# GROUPS_CONFIG_PATH=/path/to/groups.json

# 可选：如果部署机器使用 UTC，可保持配置里的 timezone=Asia/Shanghai，不需要设置 TZ
# TZ=Asia/Shanghai

# 可选：本机或服务器没有 Puppeteer 缓存浏览器时，指定系统 Chrome
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# 可选：默认 template，不需要模型密钥；后续接入兼容 OpenAI 的网关时再打开
AI_PROVIDER=template
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# AI_MODEL=gpt-4o-mini

# 智谱只读预览示例
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4-flash-250414
# AI_API_KEY=仅配置在本地或服务器环境
